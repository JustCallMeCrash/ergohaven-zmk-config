#include "keys_ru.h"
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>

&lt {
    retro-tap;
    quick-tap-ms = <175>;
};

/ {
    behaviors {
        enc_vol: enc_vol {
            compatible = "zmk,behavior-sensor-rotate";
            label = "ENC_VOL";
            #sensor-binding-cells = <0>;
            bindings = <&kp C_VOL_UP>, <&kp C_VOL_DN>;
        };
    };

    combos {
        compatible = "zmk,combos";

        combo1 {
            bindings = <&kp LS(LG(TAB))>;
            key-positions = <18 19>;
        };

        combo2 {
            bindings = <&kp LC(LG(RIGHT_BRACKET))>;
            key-positions = <44 45>;
        };

        combo3 {
            bindings = <&kp LC(LG(LEFT_BRACKET))>;
            key-positions = <40 41>;
        };

        combo4 {
            bindings = <&kp LA(LC(DELETE))>;
            key-positions = <8 9 10>;
        };

        combo5 {
            bindings = <&m4>;
            key-positions = <6 8 10>;
        };

        combo6 {
            bindings = <&m6>;
            key-positions = <18 20 22>;
        };

        combo7 {
            bindings = <&m3>;
            key-positions = <30 32 34>;
        };

        combo8 {
            bindings = <&m0>;
            key-positions = <31 32 33>;
        };

        combo9 {
            bindings = <&m5>;
            key-positions = <19 20 21>;
        };

        combo10 {
            bindings = <&m1>;
            key-positions = <44 46 48>;
        };

        combo12 {
            bindings = <&kp LC(LG(ENTER))>;
            key-positions = <28 29>;
        };

        combo13 {
            bindings = <&kp LS(LC(O))>;
            key-positions = <28 27>;
        };

        combo14 {
            bindings = <&kp LC(LS(E))>;
            key-positions = <26 27 28>;
        };
    };

    macros {
        m0: m0 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&none &kp B &kp R &kp Y &kp S &kp O &kp N &kp DOT &kp O &kp S &kp B &kp O &kp R &kp N &kp E &kp AT &kp I &kp N &kp V &kp E &kp N &kp C &kp O &kp DOT &kp C &kp O &kp M &kp TAB>;
            label = "M0";
        };

        m1: m1 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&none &kp LS(D) &kp E &kp V &kp LS(O) &kp P &kp S &kp LS(G) &kp U &kp R &kp U &kp N2 &kp N0 &kp N2 &kp N5 &kp DLLR &kp DLLR &kp ENTER>;
            label = "M1";
        };

        m2: m2 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&none &kp LS(S) &kp E &kp N &kp I &kp O &kp R &kp LS(D) &kp E &kp V &kp LS(O) &kp P &kp S &kp N2 &kp N0 &kp N2 &kp N5 &kp POUND &kp POUND &kp ENTER>;
            label = "M2";
        };

        m3: m3 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&none &kp LS(G) &kp I &kp L &kp B &kp A &kp R &kp C &kp O &kp N7 &kp N3 &kp N0 &kp N0 &kp DLLR &kp DLLR &kp DLLR &kp ENTER>;
            label = "M3";
        };

        m4: m4 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&none &kp B &kp O &kp S &kp B &kp O &kp R &kp N &kp E &kp ENTER>;
            label = "M4";
        };

        m5: m5 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&none &kp LS(D) &kp E &kp V &kp LS(O) &kp P &kp S &kp N2 &kp N0 &kp N2 &kp N6 &kp DLLR &kp DLLR &kp ENTER>;
            label = "M5";
        };

        m6: m6 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&none &kp LS(S) &kp E &kp N &kp I &kp O &kp R &kp LS(D) &kp E &kp V &kp LS(O) &kp P &kp S &kp N2 &kp N0 &kp N2 &kp N5 &kp DLLR &kp DLLR &kp ENTER>;
            label = "M6";
        };
    };

    keymap {
        compatible = "zmk,keymap";

        L0 {
            bindings = <
&kp GRAVE     &kp N1          &kp N2     &kp N3        &kp N4     &kp N5                                                                 &kp N6       &kp N7      &kp N8     &kp N9        &kp N0  &lt 6 BACKSLASH
&lt 3 TAB     &kp APOSTROPHE  &kp COMMA  &kp PERIOD    &kp P      &kp Y                                                                  &kp F        &kp G       &kp C      &kp R         &kp L   &lt 2 SLASH
&lt 2 INSERT  &kp A           &kp O      &kp E         &kp U      &kp I                                                                  &kp D        &kp H       &kp T      &kp N         &kp S   &lt 3 MINUS
&kp LSHFT     &kp SEMICOLON   &kp Q      &kp J         &kp K      &kp X          &mt LC(LEFT_SHIFT) LEFT_BRACKET    &lt 0 RIGHT_BRACKET  &kp B        &kp M       &kp W      &kp V         &kp Z   &kp RSHFT
                              &kp LGUI   &kp LEFT_ALT  &kp EQUAL  &kp BACKSPACE  &mt LCTRL DELETE                   &lt 4 SPACE          &lt 1 ENTER  &kp ESCAPE  &kp RCTRL  &kp LG(RGUI)
            >;

            display-name = "Base";
            sensor-bindings =
                <&enc_vol>,
                <&enc_vol>,
                <&enc_vol>,
                <&enc_vol>,
                <&enc_vol>,
                <&enc_vol>;

            label = "L0";
        };

        L1 {
            bindings = <
&kp ESC         &trans        &trans     &kp LA(LC(DELETE))  &trans       &kp ESCAPE                                         &trans       &kp KP_NUMLOCK   &kp KP_DIVIDE  &kp KP_ASTERISK  &kp KP_MINUS  &kp F12
&kp EQUAL       &trans        &kp HOME   &kp UP              &kp END      &kp PRINTSCREEN                                    &kp PG_UP    &kp KP_N7        &kp KP_N8      &kp KP_NUMBER_9  &kp KP_PLUS   &trans
&trans          &kp LEFT_ALT  &kp LEFT   &kp DOWN            &kp RIGHT    &trans                                             &kp PG_DN    &kp KP_NUMBER_4  &kp KP_N5      &kp KP_N6        &kp KP_PLUS   &trans
&kp LEFT_SHIFT  &kp LEFT_GUI  &kp LCTRL  &kp RC(F5)          &kp RC(F12)  &kp LC(HOME)     &kp HOME              &kp END     &kp RC(END)  &kp KP_NUMBER_1  &kp KP_N2      &kp KP_N3        &kp KP_ENTER  &kp RIGHT_SHIFT
                              &trans     &kp F5              &kp F12      &trans           &kp LC(DOWN_ARROW)    &kp RC(UP)  &trans       &kp KP_NUMBER_0  &kp KP_N0      &kp KP_DOT
            >;

            display-name = "num";
            label = "L1";
        };

        L2 {
            bindings = <
&kp ESC  &kp F1   &kp F2   &kp F3   &kp F4   &kp F5                                             &kp LS(LG(F16))  &kp LS(LG(F17))  &kp LS(LG(F18))  &kp LS(LG(F19))  &kp LS(LG(F21))  &trans
&trans   &kp F6   &kp F7   &kp F8   &kp F9   &kp F10                                            &kp LS(LG(F1))   &kp LS(LG(F2))   &kp LS(LG(F3))   &kp LS(LG(F4))   &kp LS(LG(F5))   &trans
&trans   &kp F11  &kp F12  &kp F13  &kp F14  &kp F15                                            &kp LS(LG(F6))   &kp LS(LG(F7))   &kp LS(LG(F8))   &kp LS(LG(F9))   &kp LS(LG(F10))  &kp LG(TAB)
&trans   &kp F16  &kp F17  &kp F18  &kp F19  &kp F21       &trans                &trans         &kp LS(LG(F11))  &kp LS(LG(F12))  &kp LS(LG(F13))  &kp LS(LG(F14))  &kp LS(LG(F15))  &kp RIGHT_SHIFT
                  &trans   &trans   &trans   &kp LEFT_GUI  &kp LG(LEFT_SHIFT)    &kp LG(SPACE)  &kp LG(ENTER)    &kp RS(INS)      &kp RC(INS)      &trans
            >;

            display-name = "Symbols";
            label = "L2";
        };

        L3 {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans                               &kp LG(F16)    &kp LG(F17)     &kp LG(F18)  &kp LG(F19)  &kp LG(F21)  &trans
&trans  &trans  &trans  &trans  &trans  &trans                               &kp LG(F1)     &kp LG(F2)      &kp LG(F3)   &kp LG(F4)   &kp LG(F5)   &trans
&trans  &trans  &trans  &trans  &trans  &trans                               &kp LG(F6)     &kp LG(F7)      &kp LG(F8)   &kp LG(F9)   &kp LG(F10)  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans    &trans             &kp LG(F11)    &kp LG(F12)     &kp LG(F13)  &kp LG(F14)  &kp LG(F15)  &kp RIGHT_SHIFT
                &trans  &trans  &trans  &trans  &trans    &kp LG(LA(SPACE))  &kp LG(ENTER)  &kp LS(INSERT)  &kp LC(INS)  &trans
            >;

            display-name = "Adjust";
            label = "L3";
        };

        L4 {
            bindings = <
&trans  &trans    &trans          &msc SCRL_UP    &trans           &kp ESC                                                &kp EQUAL     &kp PAGE_UP   &kp LC(F5)  &kp PG_DN            &kp LG(LA(SPACE))             &kp LG(SPACE)
&trans  &mkp MB4  &mkp LCLK       &mmv MOVE_UP    &mkp MB2         &kp ESC                                                &kp PLUS      &kp HOME      &kp UP      &kp END              &kp RALT                      &kp PRINTSCREEN
&trans  &mkp MB3  &mmv MOVE_LEFT  &mmv MOVE_DOWN  &mmv MOVE_RIGHT  &trans                                                 &kp LC(INS)   &kp LEFT      &kp DOWN    &kp RIGHT            &kp RCTRL                     &kp LC(RIGHT_SHIFT)
&trans  &trans    &trans          &msc SCRL_DOWN  &trans           &trans             &trans            &kp RS(LEFT_GUI)  &kp LS(INS)   &trans        &trans      &trans               &kp LS(LA(LC(LG(KP_ENTER))))  &kp RIGHT_SHIFT
                  &trans          &trans          &trans           &kp LC(BACKSPACE)  &kp RC(DELETE)    &trans            &kp LG(LEFT)  &kp LG(DOWN)  &kp LG(UP)  &kp LG(RIGHT_ARROW)
            >;

            label = "L4";
        };

        L5 {
            bindings = <
&trans  &trans    &trans          &msc SCRL_UP    &trans           &kp ESC                                 &kp EQUAL     &kp PAGE_UP   &kp LC(F5)  &kp PG_DN            &kp LG(LA(SPACE))             &kp LG(SPACE)
&trans  &mkp MB4  &mkp LCLK       &mmv MOVE_UP    &mkp MB2         &kp ESC                                 &kp PLUS      &kp HOME      &kp UP      &kp END              &kp RALT                      &kp PRINTSCREEN
&trans  &mkp MB3  &mmv MOVE_LEFT  &mmv MOVE_DOWN  &mmv MOVE_RIGHT  &trans                                  &trans        &kp LEFT      &kp DOWN    &kp RIGHT            &kp RCTRL                     &kp LC(RIGHT_SHIFT)
&trans  &trans    &trans          &msc SCRL_DOWN  &trans           &trans    &trans      &kp RS(LEFT_GUI)  &trans        &trans        &trans      &trans               &kp LS(LA(LC(LG(KP_ENTER))))  &kp RIGHT_SHIFT
                  &trans          &kp F5          &kp F12          &mkp MB1  &mkp MB2    &trans            &kp RS(LEFT)  &kp RS(DOWN)  &kp RS(UP)  &kp RS(RIGHT_ARROW)
            >;

            label = "L5";
        };

        L6 {
            label = "L6";
            display-name = "Adjust";
            bindings = <
&trans  &out OUT_TOG  &trans        &trans        &trans        &bt BT_CLR                                 &kp LG(LS(LC(F16)))  &kp LG(LS(LC(F17)))  &kp LG(F18)          &kp LG(LS(LC(F19)))  &kp LG(LS(LC(F21)))  &trans
&trans  &trans        &trans        &trans        &trans        &trans                                     &kp LG(LS(LC(F1)))   &kp LG(LS(LC(F2)))   &kp LG(LS(LC(F3)))   &kp LG(LS(LC(F4)))   &kp LG(LS(LC(F5)))   &trans
&trans  &trans        &trans        &trans        &trans        &trans                                     &kp LG(LS(LC(F6)))   &kp LG(LS(LC(F7)))   &kp LG(LS(LC(F8)))   &kp LG(LS(LC(F9)))   &kp LG(LS(LC(F10)))  &trans
&trans  &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4  &trans    &trans             &kp LG(LS(LC(F11)))  &kp LG(LS(LC(F12)))  &kp LG(LS(LC(F13)))  &kp LG(LC(LS(F14)))  &kp LG(LS(LC(F15)))  &kp RIGHT_SHIFT
                      &trans        &trans        &trans        &trans        &trans    &kp LG(LA(SPACE))  &kp LG(ENTER)        &trans               &trans               &trans
            >;
        };
    };
};
