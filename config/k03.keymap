#include "keys_ru.h"
#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>

/ {
    behaviors {
        enc_vol: enc_vol {
            compatible = "zmk,behavior-sensor-rotate";
            label = "ENC_VOL";
            #sensor-binding-cells = <0>;
            bindings = <&kp C_VOL_UP>, <&kp C_VOL_DN>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        L0 {
            bindings = <
&kp GRAVE     &kp N1          &kp N2     &kp N3      &kp N4        &kp N5                                                                 &kp N6       &kp N7      &kp N8    &kp N9        &kp N0  &lt 5 BACKSLASH
&lt 3 TAB     &kp APOSTROPHE  &kp COMMA  &kp PERIOD  &kp P         &kp Y                                                                  &kp F        &kp G       &kp C     &kp R         &kp L   &lt 2 SLASH
&lt 2 INSERT  &kp A           &kp O      &kp E       &kp U         &kp I                                                                  &kp D        &kp H       &kp T     &kp N         &kp S   &lt 3 MINUS
&kp LSHFT     &kp SEMICOLON   &kp Q      &kp J       &kp K         &kp X          &mt LC(LEFT_SHIFT) LEFT_BRACKET    &lt 5 RIGHT_BRACKET  &kp B        &kp M       &kp W     &kp V         &kp Z   &kp RSHFT
                              &kp LGUI   &kp LGUI    &kp LEFT_ALT  &kp BACKSPACE  &mt LCTRL DELETE                   &lt 4 SPACE          &lt 1 ENTER  &kp ESCAPE  &kp RALT  &kp LG(RGUI)
            >;

            display-name = "Base";
            sensor-bindings =
                <&enc_vol>,
                <&enc_vol>,
                <&enc_vol>,
                <&enc_vol>,
                <&enc_vol>,
                <&enc_vol>;

            label = "L0";
        };

        L1 {
            bindings = <
&kp ESC         &trans        &trans     &kp LA(LC(DELETE))  &trans       &kp ESCAPE                                         &trans       &kp KP_NUMLOCK   &kp KP_DIVIDE  &kp KP_ASTERISK  &kp KP_MINUS  &kp F12
&kp EQUAL       &trans        &kp HOME   &kp UP              &kp END      &kp PRINTSCREEN                                    &kp PG_UP    &kp KP_N7        &kp KP_N8      &kp KP_NUMBER_9  &kp KP_PLUS   &trans
&trans          &kp LEFT_ALT  &kp LEFT   &kp DOWN            &kp RIGHT    &trans                                             &kp PG_DN    &kp KP_NUMBER_4  &kp KP_N5      &kp KP_N6        &kp KP_PLUS   &trans
&kp LEFT_SHIFT  &kp LEFT_GUI  &kp LCTRL  &kp RC(F5)          &kp RC(F12)  &kp LC(HOME)     &kp HOME              &kp END     &kp RC(END)  &kp KP_NUMBER_1  &kp KP_N2      &kp KP_N3        &kp KP_ENTER  &kp RIGHT_SHIFT
                              &trans     &kp F5              &kp F12      &trans           &kp LC(DOWN_ARROW)    &kp RC(UP)  &trans       &kp KP_NUMBER_0  &kp KP_N0      &kp KP_DOT
            >;

            display-name = "num";
            label = "L1";
        };

        L2 {
            bindings = <
&kp ESC  &kp F1   &kp F2   &kp F3   &kp F4   &kp F5                                             &kp LS(LG(F16))  &kp LS(LG(F17))  &kp LS(LG(F18))  &kp LS(LG(F19))  &kp LS(LG(F21))  &trans
&trans   &kp F6   &kp F7   &kp F8   &kp F9   &kp F10                                            &kp LS(LG(F1))   &kp LS(LG(F2))   &kp LS(LG(F3))   &kp LS(LG(F4))   &kp LS(LG(F5))   &trans
&trans   &kp F11  &kp F12  &kp F13  &kp F14  &kp F15                                            &kp LS(LG(F6))   &kp LS(LG(F7))   &kp LS(LG(F8))   &kp LS(LG(F9))   &kp LS(LG(F10))  &kp LG(TAB)
&trans   &kp F16  &kp F17  &kp F18  &kp F19  &kp F21       &trans                &trans         &kp LS(LG(F11))  &kp LS(LG(F12))  &kp LS(LG(F13))  &kp LS(LG(F14))  &kp LS(LG(F15))  &kp RIGHT_SHIFT
                  &trans   &trans   &trans   &kp LEFT_GUI  &kp LG(LEFT_SHIFT)    &kp LG(SPACE)  &kp LG(ENTER)    &kp RS(INS)      &kp RC(INS)      &trans
            >;

            display-name = "Symbols";
            label = "L2";
        };

        adj {
            bindings = <
&bootloader  &trans  &trans  &trans  &trans  &trans                    &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2      &bt BT_SEL 3  &bt BT_SEL 4  &bt BT_CLR_ALL
&trans       &trans  &trans  &trans  &trans  &trans                    &trans        &trans        &trans            &trans        &trans        &studio_unlock
&trans       &trans  &trans  &trans  &trans  &trans                    &out OUT_BLE  &kp C_VOL_DN  &kp C_MUTE        &kp C_VOL_UP  &trans        &trans
&trans       &trans  &trans  &trans  &trans  &trans  &trans    &trans  &out OUT_USB  &kp C_PREV    &kp C_PLAY_PAUSE  &kp C_NEXT    &trans        &trans
                     &trans  &trans  &trans  &trans  &trans    &trans  &trans        &trans        &trans            &trans
            >;

            display-name = "Adjust";
        };

        layer_4 {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans                    &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans                    &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans                    &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans  &trans
                &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans
            >;
        };

        layer_5 {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans                    &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans                    &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans                    &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans  &trans
                &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans
            >;
        };

        layer_6 {
            bindings = <
&trans  &trans  &trans  &trans  &trans  &trans                    &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans                    &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans                    &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans  &trans
                &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans
            >;
        };
    };
};
